SUPABASE__URL=https://example.supabase.co
SUPABASE__ANON_KEY=replace-with-supabase-anon-key
SUPABASE__SERVICE_KEY=replace-with-supabase-service-role-key
GROQ__API_KEY=replace-with-groq-api-key
GROQ__CHAT_MODEL=llama-3.3-70b-versatile
GROQ__VISION_MODEL=llama-3.2-11b-vision-preview
GROQ__WHISPER_MODEL=whisper-large-v3
CHROMA__PERSIST_DIR=./chroma
CHROMA__COLLECTION_MANUAL=manual_chunks
CHROMA__COLLECTION_CASES=diagnostic_cases
EMBEDDINGS__MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
APP__ENV=development
APP__VERSION=0.1.0
APP__CORS_ORIGINS=["http://localhost:3000"]
